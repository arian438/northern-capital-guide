# Server
PORT=5000
NODE_ENV=production

# Database (локально — отдельные переменные, на Vercel — DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=northern_capital_guide

# Для Vercel / Neon / Supabase — одна строка подключения:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT
JWT_SECRET=замените-на-длинный-случайный-ключ
JWT_REFRESH_SECRET=замените-на-другой-случайный-ключ
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (для CORS; на Vercel можно указать ваш домен)
FRONTEND_URL=https://ваш-проект.vercel.app
